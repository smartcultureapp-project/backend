model CompanyAnalysis {
  id                        String   @id @default(nanoid())
  sessionId                 String
  companyId                 String?
  companyName               String
  jobRole                   String
  rawAdditionalInfo         String?

  talents                   Json     @default("[]")
  techStack                 Json     @default("[]")
  cultureKeywords           Json     @default("[]")
  interviewStyle            Json     @default("[]")
  recommendedQuestionAngles Json     @default("[]")
  interviewAvoid            Json     @default("[]")
  interviewSuccessTips      Json     @default("[]")
  interviewTips             Json     @default("[]")
  actualQuestions           Json     @default("[]")
  searchSources             Json     @default("[]")
  rawSearchResults          Json?

  interviewProcess          String   @default("")
  companySummary            String
  jobRoleSummary            String
  confidenceScore           Int      @default(0)
  researchedAt              DateTime @default(now())
  createdAt                 DateTime @default(now())

  @@map("company_analysis")
}
