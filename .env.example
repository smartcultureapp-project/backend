# 테스트 모드: API 키 없이 SSE·DB 흐름 확인 (MOCK_ANALYSIS=true)
# MOCK_ANALYSIS=true

ANTHROPIC_API_KEY=your_key_here
BRAVE_SEARCH_API_KEY=your_key_here

# 로컬 Docker 사용 시:
DATABASE_URL="postgresql://postgres:password@localhost:5432/interview_coach?schema=public"

