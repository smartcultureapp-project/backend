# 테스트 모드: API 키 없이 SSE·DB 흐름 확인 (MOCK_ANALYSIS=true)
# MOCK_ANALYSIS=true

# LLM 모델 선택 (anthropic | openai | google)
# anthropic: Claude Haiku (기본, 품질 우수)
# openai: GPT-4o-mini (약 5배 저렴)
# google: Gemini 2.0 Flash (저렴, 빠름)
# LLM_PROVIDER=anthropic

# Anthropic 사용 시 모델 (haiku-4.5 | haiku-3.5 | haiku-3)
# haiku-4.5: $1/$5 per 1M (기본, 최신)
# haiku-3.5: $0.80/$4 (20% 저렴, legacy)
# haiku-3: $0.25/$1.25 (75% 저렴, deprecated 2026-04)
# ANTHROPIC_MODEL=haiku-4.5

# JWT 인증 (프로덕션에서는 반드시 강한 랜덤 문자열 — NODE_ENV=production 일 때 기본값 사용 불가)
JWT_SECRET=your_jwt_secret_here

# API 문서 (OpenAPI / Swagger / Scalar). false 로 끄기
# API_DOCS_ENABLED=true

ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# GOOGLE_GENERATIVE_AI_API_KEY=your_key_here
BRAVE_SEARCH_API_KEY=your_key_here

# (선택) Firecrawl API 키 — 설정 시 페이지 스크래핑에 Firecrawl 사용, 미설정 시 기본 fetch
# FIRECRAWL_API_KEY=fc-your_key_here

# 로컬 Docker 사용 시:
DATABASE_URL="postgresql://postgres:password@localhost:5432/interview_coach?schema=public"

# Neon 무료 플랜 사용 시 (sslmode=verify-full로 경고 방지):
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=verify-full"
